# SvelteKit build output
.svelte-kit/
build/

# Node
node_modules/

# Environment and secrets
.env
.env.local
.env.*
!.env.example
.dev.vars

# Wrangler
.wrangler/

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Pagefind (generated at build time)
build/_pagefind/

# OS files
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~

# Playwright
test-results/

# Ad hoc review/debug scripts and their output (an underscore-prefixed `-tmp` script is a
# scratch tool for the pass that wrote it, not shipped tooling).
scripts/_*-tmp.mjs
.review-shots/

# MW export plaintext must never land in git; only the .age copies are committed
data/membershipworks/*.csv
